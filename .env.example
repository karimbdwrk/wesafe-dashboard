NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACER
STRIPE_SECRET_KEY=sk_test_REMPLACER
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER

# Stripe Price IDs — abonnements (dashboard Stripe > Products)
# Standard+ : 19€/mois ou 199€/an
STRIPE_PRICE_STANDARD_PLUS_MONTHLY=price_REMPLACER
STRIPE_PRICE_STANDARD_PLUS_YEARLY=price_REMPLACER
# Premium : 25€/mois ou 249€/an
STRIPE_PRICE_PREMIUM_MONTHLY=price_REMPLACER
STRIPE_PRICE_PREMIUM_YEARLY=price_REMPLACER

# Stripe Price ID — achat de crédits Last Minute (paiement unique)
# Pack 10 crédits : 30€ (au lieu de 50€)
STRIPE_PRICE_LASTMINUTE_PACK=price_REMPLACER

# Prix ad-hoc (définis dans le code, pas de Price ID Stripe)
# Last Minute one-shot (par offre) : 6€     → api/stripe/create-lastminute-oneshot
# Sponsoring 1 semaine              : 9,99€  → api/stripe/create-sponsorship-session
# Sponsoring 2 semaines             : 17,99€
# Sponsoring 1 mois                 : 29,99€

SUPABASE_SERVICE_ROLE_KEY=eyJ...
